    "build": "npx tsc",
    "start-prod": "npm build && node ./dist/index.js",
    "tsc": "npx tsc"
  },
  "dependencies": {
    "@cml/express-backend": "^0.6.1",
    "@prisma/client": "^4.4.0",
    "ajv": "^8.11.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.13",
    "nodemon": "^2.0.19",
    "prisma": "^4.4.0",
    "ts-node": "^10.9.1",
    "typescript": "^4.8.4"
  }
}
