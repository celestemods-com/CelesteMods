{
  "name": "@cml/express-db-import-server",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch src/ --watch node_modules/.prisma --ext ts,js,json,node,prisma --ignore prisma/ ./src/index.ts",
